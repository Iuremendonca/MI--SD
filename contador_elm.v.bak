module contador_elm (
    input clk,
    input reset,
    input incrementa_pixel,
    input incrementa_neuronio,
    input limpa_contadores,
    output [9:0] conta_pixel,    // 0 a 783 (10 bits)
    output [6:0] conta_neuronio, // 0 a 127 (7 bits)
    output fim_pixels,           // Ativo quando chega em 784
    output fim_neuronios         // Ativo quando chega em 128
);
    reg [9:0] p_reg;
    reg [6:0] n_reg;

    always @(posedge clk or posedge reset) begin
        if (reset || limpa_contadores) begin
            p_reg <= 0;
            n_reg <= 0;
        end else begin
            if (incrementa_pixel) p_reg <= p_reg + 1;
            if (incrementa_neuronio) n_reg <= n_reg + 1;
        end
    end

    assign conta_pixel = p_reg;
    assign conta_neuronio = n_reg;
    assign fim_pixels = (p_reg == 783);    // [cite: 25]
    assign fim_neuronios = (n_reg == 127); // [cite: 23]
endmodule